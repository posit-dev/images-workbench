{#-
Below are imports for Bakery's macros. If any are unneeded, they can be removed.
Bakery handles bootstrapping the files into template rendering.
-#}
{%- import "apt.j2" as apt -%}
FROM docker.io/library/ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive

{{ apt.run_setup() }}

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      ca-certificates curl jq unzip && \
    rm -rf /var/lib/apt/lists/*

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Download positron-server tarball from CDN
RUN mkdir -p /opt/positron/bin/positron-server && \
    curl -fsSL -o /tmp/positron.tar.gz "{{ positron_url }}" && \
    tar -xzf /tmp/positron.tar.gz -C /tmp && \
    mv /tmp/vscode-reh-web-linux-* /opt/positron/bin/positron-server/bundled && \
    rm /tmp/positron.tar.gz

# Download positron docs from CDN
RUN mkdir -p /opt/positron/docs/positron && \
    curl -fsSL -o /tmp/docs.zip "https://cdn.posit.co/positron/release/docs/positron-workbench-docs-{{ positron_docs_version }}.zip" && \
    unzip -qo /tmp/docs.zip -d /opt/positron/docs/positron && \
    rm /tmp/docs.zip

# Download latest positron-session-init binary from CDN
RUN BINARY_URL=$(curl -fsSL "https://cdn.posit.co/pwb-components/positron-session-init/latest.json" \
      | jq -r '.artifacts["linux-x86_64"].url') && \
    curl -fsSL -o /tmp/positron-session-init.tar.gz "$BINARY_URL" && \
    tar -xzf /tmp/positron-session-init.tar.gz -C /usr/local/bin && \
    chmod 755 /usr/local/bin/positron-session-init && \
    rm /tmp/positron-session-init.tar.gz

# Final image
FROM docker.io/library/ubuntu:24.04 AS build
LABEL org.opencontainers.image.base.name="docker.io/library/ubuntu:24.04"

ARG DEBIAN_FRONTEND=noninteractive

{{ apt.run_update_upgrade() }}

COPY --from=builder --chmod=755 /usr/local/bin/positron-session-init /usr/local/bin/positron-session-init
COPY --from=builder --chmod=755 /opt/positron /opt/positron

ENTRYPOINT ["/usr/local/bin/positron-session-init"]
