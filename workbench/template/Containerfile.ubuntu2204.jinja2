{% if not is_minimal -%}
ARG PYTHON_VERSION="{{ python_version }}"
ARG R_VERSION="{{ r_version }}"
{%- endif %}
FROM posit/base:ubuntu2204

### ARG declarations ###
ARG DEBIAN_FRONTEND=noninteractive
ARG SCRIPTS_DIR=/opt/positscripts
{% if not is_minimal -%}
ARG PYTHON_VERSION="{{ python_version }}"
ARG R_VERSION="{{ r_version }}"
{%- endif %}
ARG WORKBENCH_VERSION="{{ workbench_version }}"
ARG RSTUDIO_INSTALL_NO_LICENSE_INITIALIZATION=1

### Install System Packages ###
COPY common/ubuntu/22.04/packages.txt /tmp/packages.txt
{% if not is_minimal -%}
COPY common/ubuntu/22.04/optional_packages.txt /tmp/optional_packages.txt
{%- endif %}
RUN $SCRIPTS_DIR/apt.sh --update upgrade \
    && $SCRIPTS_DIR/apt.sh install $(cat /tmp/packages.txt) \
    && rm -f /tmp/packages.txt \
    {% if not is_minimal -%}
    && $SCRIPTS_DIR/apt.sh install $(cat /tmp/optional_packages.txt) \
    && rm -f /tmp/optional_packages.txt
    {%- endif %}
    && $SCRIPTS_DIR/apt.sh --clean \

### Install Workbench {{ workbench_version }} ###
COPY common/ubuntu/scripts/install_workbench.sh /tmp/install_workbench.sh
RUN OS_URL=jammy /tmp/install_workbench.sh

### Install Quarto to PATH ###
RUN ln -s /lib/rstudio-server/bin/quarto/bin/quarto /usr/local/bin/quarto

{% if not is_minimal -%}
### Install TinyTeX using Quarto ###
RUN $SCRIPTS_DIR/install_quarto.sh --install-tinytex --add-path-tinytex

### Install Jupyter and extensions ###
RUN $SCRIPTS_DIR/install_python.sh --install-jupyter --install-jupyter-kernel -- ${PYTHON_VERSION}
{%- endif %}

### Add wait-for-it.sh to PATH ###
RUN ln -s $SCRIPTS_DIR/wait-for-it.sh /usr/local/bin/wait-for-it.sh \
    && chmod +x /usr/local/bin/wait-for-it.sh

### Copy startup scripts ###
COPY --chmod=0775 scripts/startup.sh /usr/local/bin/startup.sh
COPY startup/launcher /startup/launcher
COPY startup/base /startup/base
COPY supervisord.conf /etc/supervisor/supervisord.conf
{% if not is_minimal -%}
COPY startup/user-provisioning /startup/user-provisioning
COPY --chmod=600 conf/sssd/sssd.conf /etc/sssd/sssd.conf
{%- endif %}
COPY conf/rstudio /etc/rstudio
RUN

### Configure Workbench ###
RUN mkdir -p /var/lib/rstudio-server/monitor/log \
    && chown -R rstudio-server:rstudio-server /var/lib/rstudio-server/monitor \
    && mkdir -p /startup/custom/ \
    && printf '\n# allow home directory creation\nsession required pam_mkhomedir.so skel=/etc/skel umask=0022' >> /etc/pam.d/common-session \
    && echo "RSPM=https://packagemanager.posit.co/cran/__linux__/jammy/latest" > /etc/rstudio/repos.conf \
    && echo "CRAN=https://packagemanager.posit.co/cran/__linux__/jammy/latest" >> /etc/rstudio/repos.conf

EXPOSE 8787/tcp
EXPOSE 5559/tcp

ENTRYPOINT []
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]
