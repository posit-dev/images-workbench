FROM docker.io/library/ubuntu:22.04
LABEL org.opencontainers.image.base.name="docker.io/library/ubuntu:22.04"

ADD --chmod=750 https://saipittwood.blob.core.windows.net/packages/pti /usr/local/bin/pti

### ARG declarations ###
ARG DEBIAN_FRONTEND=noninteractive
ARG SCRIPTS_DIR=/opt/posit/scripts
{%- if not is_minimal %}
ARG PYTHON_VERSION="{{ python_version }}"
ARG R_VERSION="{{ r_version }}"
{%- endif %}
ARG WORKBENCH_VERSION="{{ image_version }}"
ARG RSTUDIO_INSTALL_NO_LICENSE_INITIALIZATION=1

ENV STARTUP_DEBUG_MODE 0
ENV RSW_LICENSE ""
ENV RSW_LICENSE_SERVER ""
ENV RSW_TESTUSER rstudio
ENV RSW_TESTUSER_PASSWD rstudio
ENV RSW_TESTUSER_UID 10000
ENV RSW_LAUNCHER true
ENV RSW_LAUNCHER_TIMEOUT 10
ENV DIAGNOSTIC_DIR /var/log/rstudio
ENV DIAGNOSTIC_ENABLE false
ENV DIAGNOSTIC_ONLY false

### Install System Packages ###
COPY {{ rel_path }}/deps/ubuntu2204_packages.txt /tmp/ubuntu2204_packages.txt
{% if not is_minimal -%}
COPY {{ rel_path }}/deps/ubuntu2204_optional_packages.txt /tmp/ubuntu2204_optional_packages.txt
{%- endif %}
RUN pti container bootstrap \
    && pti container syspkg upgrade --dist \
    && pti container syspkg install -f /tmp/ubuntu2204_packages.txt \
    && rm -f /tmp/ubuntu2204_packages.txt \
    {%- if not is_minimal %}
    && pti container syspkg install -f /tmp/ubuntu2204_optional_packages.txt \
    && rm -f /tmp/ubuntu2204_optional_packages.txt \
    {%- endif %}
    && pti container syspkg clean

### Install Workbench {{ image_version }} ###
COPY {{ rel_path }}/scripts/install_workbench.sh /tmp/install_workbench.sh
RUN OS_URL=jammy /tmp/install_workbench.sh

### Install Quarto to PATH ###
RUN ln -s /lib/rstudio-server/bin/quarto/bin/quarto /usr/local/bin/quarto

{% if not is_minimal -%}
### Install TinyTeX using Quarto ###
RUN pti quarto install-tinytex --quarto-path /lib/rstudio-server/bin/quarto/bin/quarto --add-path-tinytex

### Install R versions ###
RUN pti r install -V ${R_VERSION} --default --add-to-path

### Install Python and install Jupyter and extensions ###
RUN pti python install -V ${PYTHON_VERSION} --add-jupyter-kernel --default --add-to-path \
    && pti python install-jupyter -V ${PYTHON_VERSION}
{%- endif %}

### Copy startup scripts ###
COPY --chmod=0775 {{ rel_path }}/scripts/startup.sh /usr/local/bin/startup.sh
COPY {{ rel_path }}/startup/launcher /startup/launcher
COPY {{ rel_path }}/startup/base /startup/base
COPY {{ rel_path }}/startup/supervisord.conf /etc/supervisor/supervisord.conf
{%- if not is_minimal %}
COPY {{ rel_path }}/startup/user-provisioning /startup/user-provisioning
COPY --chmod=600 {{ rel_path }}/conf/sssd/sssd.conf /etc/sssd/sssd.conf
{%- endif %}
COPY {{ rel_path }}/conf/rstudio /etc/rstudio

### Configure Workbench ###
RUN mkdir -p /var/lib/rstudio-server/monitor/log \
    && chown -R rstudio-server:rstudio-server /var/lib/rstudio-server/monitor \
    && mkdir -p /startup/custom/ \
    && printf '\n# allow home directory creation\nsession required pam_mkhomedir.so skel=/etc/skel umask=0077\n' >> /etc/pam.d/common-session \
    && echo "RSPM=https://packagemanager.posit.co/cran/__linux__/jammy/latest" > /etc/rstudio/repos.conf \
    && echo "CRAN=https://packagemanager.posit.co/cran/__linux__/jammy/latest" >> /etc/rstudio/repos.conf

{% if not is_minimal -%}
LABEL co.posit.image.tools.python="{{ python_version }}" \
      co.posit.image.tools.r="{{ r_version }}"
{%- endif %}

EXPOSE 8787/tcp
EXPOSE 5559/tcp
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]
